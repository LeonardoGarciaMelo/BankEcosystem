# ============================================================
# Bank Ecosystem — Environment Variables
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# .env is gitignored and never committed — it holds real credentials.
# This file (.env.example) is committed as a template/reference only.
# ============================================================

# ── PostgreSQL ────────────────────────────────────────────
DB_USER=admin
DB_PASSWORD=change_me
DB_NAME=bank_api_db

# ── RabbitMQ ──────────────────────────────────────────────
RABBIT_USER=admin
RABBIT_PASSWORD=change_me
INTERNAL_API_KEY=RandomKey
